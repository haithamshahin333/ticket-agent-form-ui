# Copy to .env and fill in. `.env` is gitignored — never commit real keys.

# --- Model (OpenAI-compatible; see src/agent/model.py to change providers) ---
# init_chat_model id: "<provider>:<model>", e.g. openai:gpt-5-mini
MODEL=openai:gpt-5-mini
OPENAI_API_KEY=sk-...
# Optional: route OpenAI-compatible calls through a workshop / gateway endpoint.
# OPENAI_BASE_URL=https://<your-openai-gateway>/v1

# --- LangSmith tracing (optional) --------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=ticket-agent-ui
